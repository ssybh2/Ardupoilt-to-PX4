+cleanup_sim()
+{
+	local pid
+
+	if [ "${CLEANUP_DONE:-0}" -eq 1 ]; then
+		return
+	fi
+
+	CLEANUP_DONE=1
+
+	for pid in ${PX4_PID:-0} ${SIM_PID:-0} ${GUI_PID:-0}; do
+		if [ "$pid" -gt 0 ] 2>/dev/null && kill -0 "$pid" 2>/dev/null; then
+			kill "$pid" 2>/dev/null || true
+		fi
+	done
+
+	sleep 1
+
+	for pid in ${PX4_PID:-0} ${SIM_PID:-0} ${GUI_PID:-0}; do
+		if [ "$pid" -gt 0 ] 2>/dev/null && kill -0 "$pid" 2>/dev/null; then
+			kill -9 "$pid" 2>/dev/null || true
+		fi
+	done
+
+	wait ${PX4_PID:-0} ${SIM_PID:-0} ${GUI_PID:-0} 2>/dev/null || true
+}
+
+trap cleanup_sim EXIT
+trap 'cleanup_sim; exit 130' INT
+trap 'cleanup_sim; exit 143' TERM
 
